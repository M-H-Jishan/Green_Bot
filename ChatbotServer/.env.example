# ============================================================
# Green Bot Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# For local development, most defaults work out of the box.

# ---- Django Core ----
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database ----
# Leave empty to use SQLite (zero-config). Set for PostgreSQL.
# DATABASE_URL=postgres://user:password@localhost:5432/greenbot

# ---- LLM Provider ----
# Choose which AI provider to use: "openai" or "claude"
LLM_PROVIDER=openai

# OpenAI settings (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude settings (required if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ---- Custom Data ----
# Path to your JSON data file (relative to project root or absolute)
DATA_FILE_PATH=chatbot/data/university_data.json

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ---- Security (set to True in production) ----
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ---- Rate Limiting ----
RATE_LIMIT_PER_MINUTE=20

# ---- Cache (optional) ----
# Leave empty to use local memory cache. Set for Redis.
# REDIS_URL=redis://localhost:6379/1

# ---- Email (optional, for error notifications) ----
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=your-password

# ---- Logging ----
LOG_LEVEL=INFO
